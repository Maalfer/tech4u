# =========================================================
# Tech4U Backend — Variables de Entorno (EJEMPLO)
# Copia este archivo como .env y rellena los valores reales
# =========================================================

# JWT
SECRET_KEY=cambia-esto-por-una-clave-segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Base de datos
DATABASE_URL=sqlite:///./tech4u.db
# DATABASE_URL=postgresql://user:password@localhost/tech4u

# Redis
REDIS_URL=redis://localhost:6379/0

# =========================================================
# STRIPE — MODO TEST
# Obtén tus claves en: https://dashboard.stripe.com/test/apikeys
# =========================================================

# Clave SECRETA de Stripe (empieza por sk_test_...)
STRIPE_SECRET_KEY=sk_test_REEMPLAZA_AQUI

# Clave PÚBLICA de Stripe (empieza por pk_test_...)
STRIPE_PUBLISHABLE_KEY=pk_test_REEMPLAZA_AQUI

# Secret del webhook (whsec_...) — obtén con: stripe listen --forward-to localhost:8000/subscriptions/webhook
# Déjalo vacío si no usas la CLI de Stripe en local
STRIPE_WEBHOOK_SECRET=

# URL base del frontend
FRONTEND_URL=http://localhost:5174
