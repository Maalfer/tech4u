FROM ubuntu:22.04

# Install basic tools
RUN apt-get update && apt-get install -y \
    sudo \
    iproute2 \
    net-tools \
    iputils-ping \
    curl \
    nano \
    vim \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Create student user
RUN useradd -m -s /bin/bash student

# Set working directory
WORKDIR /home/student

# Default to student user
USER student

CMD ["/bin/bash"]
